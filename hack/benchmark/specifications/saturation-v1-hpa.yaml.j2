# Specification for the Saturation V1 HPA benchmark.
#
# Reuses templates and defaults from the llm-d-benchmark repo (base_dir) but
# points scenario_file at the local hack/ scenario so analytics labels are
# "saturation-v1-hpa" rather than "inference-scheduling-wva".
#
# Use with:
#   make benchmark-standup-hpa BENCHMARK_NAMESPACE=<namespace>
#   make benchmark-run-hpa     BENCHMARK_NAMESPACE=<namespace>
{% set base_dir = base_dir | default('../') -%}
base_dir: {{ base_dir }}

# [REQUIRED]
values_file:
  path: {{ base_dir }}/config/templates/values/defaults.yaml

# [REQUIRED]
template_dir:
  path: {{ base_dir }}/config/templates/jinja

# [OPTIONAL]
scenario_file:
  path: {{ base_dir }}/../hack/benchmark/scenarios/saturation-v1-hpa.yaml
